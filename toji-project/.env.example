# HOMELANDER Bot Environment Configuration
# 
# SECURITY: This file is a TEMPLATE ONLY
# NEVER commit your actual .env file to git!
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Add .env to .gitignore (already done)
# 4. Never commit .env or share it publicly

# Telegram Bot Token (get from @BotFather on Telegram)
# Format: numeric_id:alphanumeric_string
# Example: 1234567890:ABCdefGHIjklmno_PQRstUVwxyz123456
BOT_TOKEN=paste_your_bot_token_here_without_quotes

# Web App URL (where frontend is hosted)
WEBAPP_URL=http://localhost:5173

# Backend API URL (where API server runs)
BACKEND_URL=http://localhost:8000

# Owner Telegram ID (receives notifications)
OWNER_ID=8606381959

